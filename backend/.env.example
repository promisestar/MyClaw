# ============================================================================
# HelloClaw 环境变量配置（示例）
# 复制为 .env 并填入真实密钥后即可启动
# ============================================================================

# ==========================
# LLM 配置
# ==========================
# 推荐：modelscope 提供的 GLM 系列（免费额度）
# LLM_MODEL_ID=ZhipuAI/GLM-5
# LLM_API_KEY=ms-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# LLM_BASE_URL=https://api-inference.modelscope.cn/v1

# 或：aihubmix（OpenAI 兼容代理）
# LLM_MODEL_ID=coding-glm-5-free
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://aihubmix.com/v1

# 或：内部 llmproxy（需具体 model_id 经管理员授权）
# LLM_MODEL_ID=
# LLM_API_KEY=
# LLM_BASE_URL=

LLM_MODEL_ID=
LLM_API_KEY=
LLM_BASE_URL=

# ==========================
# 搜索工具
# ==========================
# Tavily 搜索（推荐）- 获取 API 密钥：https://tavily.com/
TAVILY_API_KEY=

# SerpApi 搜索（备选）- 获取 API 密钥：https://serpapi.com/
SERPAPI_API_KEY=

# ==========================
# 服务配置
# ==========================
PORT=8000
CORS_ORIGINS=http://localhost:5173

# ==========================
# 工作空间配置
# ==========================
WORKSPACE_PATH=~/.helloclaw/workspace

# 上传：单文件最大字节数（默认 10MB）
# UPLOAD_MAX_BYTES=10485760

# ================================
# Qdrant 向量数据库配置
# ================================
# 获取 API 密钥：https://cloud.qdrant.io/
# 使用 Qdrant 云服务（推荐）
QDRANT_URL=
QDRANT_API_KEY=

# 或使用本地 Qdrant（需要 Docker）
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# Qdrant 集合配置
QDRANT_COLLECTION=rag_knowledge_base
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=cosine
QDRANT_TIMEOUT=30

# ==========================
# 记忆写入路径去重配置
# ==========================
# 当前 MyClaw 始终启用 L1 字面去重（hash 完全相同的内容会复用旧记忆，
# 强化 last_decay_ts + access_count++），零误判。
#
# L2 语义去重相似度阈值（默认 1.0 = 关闭）：
#   - 1.0  → 关闭 L2（推荐默认值，配合当前 all-MiniLM-L6-v2 模型）
#   - <1.0 → 启用 L2；同分类内 top-1 cosine ≥ 阈值即视为重复
#
# 为何默认关闭：默认 embedding ``all-MiniLM-L6-v2`` 对中文反义/同义辨别力不足，
# 实测反义（"我喜欢简洁" vs "我讨厌简洁"）相似度有时反高于同义改写
# （"我喜欢简洁" vs "我偏好简洁"），无法用固定阈值同时兼顾。
# 换用对中文友好的 embedding（如 BAAI/bge-small-zh-v1.5）后，把阈值降到
# 0.90~0.93 即可启用 L2。
MEMORY_DEDUPE_THRESHOLD=1.0

# ==========================
# 嵌入（Embedding）配置
# ==========================
# EMBED_MODEL_TYPE: local（默认，sentence-transformers）或 dashscope（阿里云）
# - local 默认模型：sentence-transformers/all-MiniLM-L6-v2
# - dashscope 默认模型：text-embedding-v3（需阿里云 API Key）
EMBED_MODEL_TYPE=local
EMBED_MODEL_NAME=
EMBED_API_KEY=
EMBED_BASE_URL=

# 更好的中文 embedding 示例（启用后建议清空 Qdrant collection 重建索引）
# EMBED_MODEL_TYPE=local
# EMBED_MODEL_NAME=BAAI/bge-small-zh-v1.5

# 或直接指定 HF 快照目录（已离线下载时）
# EMBED_MODEL_PATH=C:\Users\<user>\.cache\huggingface\hub\models--sentence-transformers--all-MiniLM-L6-v2\snapshots\<snapshot_id>

# 强制离线：EMBED_LOCAL_FILES_ONLY=1
# 允许联网校验更新：EMBED_LOCAL_FILES_ONLY=0

# 是否启用 RAG 重排序
RERANK_ENABLED=true

# ================================
# GitHub API 配置
# ================================
# GitHub Personal Access Token - 用于访问 GitHub API
# 获取方式：https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=

# ==========================
# 外部 Bridge（复用 MyClaw/bridge）
# ==========================
# 启用外部软件消息接收器（ExternalSoftwareReceiver）
# - 设置 EXTERNAL_BRIDGE_ENABLED=true 或者提供 EXTERNAL_BRIDGE_URL 才会启用
EXTERNAL_BRIDGE_ENABLED=false
# WebSocket Bridge 地址（MyClaw/bridge 默认）
EXTERNAL_BRIDGE_URL=ws://127.0.0.1:3001
# 若 MyClaw/bridge 设置了 BRIDGE_TOKEN，则这里填同一个 token
# EXTERNAL_BRIDGE_TOKEN=
# 允许的 sender_id 白名单：逗号分隔；"*" 表示允许所有；空表示拒绝所有
EXTERNAL_BRIDGE_ALLOW_FROM=*
# 连接超时/单条消息处理超时（秒）
# EXTERNAL_BRIDGE_CONNECT_TIMEOUT_S=10
# EXTERNAL_BRIDGE_HANDLE_TIMEOUT_S=120

# ==========================
# 多模态输入配置
# ==========================
# 图片传给 VLM 的方式：base64（默认，本地部署最稳）或 url（依赖下方公网前缀）
MULTIMODAL_IMAGE_MODE=base64
# URL 模式下的公网可访问前缀；启用时后端会自动 mount /files → workspace/uploads
# MULTIMODAL_PUBLIC_BASE_URL=http://your-host:8000/files
# 单张图片在上传期的字节上限（MB，默认 10MB；实际发给 VLM 前还会用 Pillow 压缩到 5MB 以内）
MULTIMODAL_MAX_IMAGE_MB=10
# 单张图片送给 VLM 时压缩到的目标大小上限（MB，默认 5MB）
# 仅 base64 模式生效；URL 模式直接走原图
# 注：不要设过大，否则会显著消耗 VLM 上下文
# （受影响的参数：build_image_part 的 max_mb）
# 单文档上传字节硬上限（默认 10MB），文档（pdf/docx/xlsx/txt 等）超出 → 413 拒绝
MULTIMODAL_DOC_MAX_BYTES=10485760
