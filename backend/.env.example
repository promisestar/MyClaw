# ============================================================================
# HelloClaw 环境变量配置
# ============================================================================

# LLM 配置
LLM_MODEL_ID=
LLM_API_KEY=
LLM_BASE_URL=

# 服务配置
PORT=8000
CORS_ORIGINS=http://localhost:5173

# 工作空间配置
WORKSPACE_PATH=~/.helloclaw/workspace

# 上传：单文件最大字节数（默认 10MB）
# UPLOAD_MAX_BYTES=10485760