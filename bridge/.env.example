# ===== Bridge =====
BRIDGE_PORT=3001
BRIDGE_TOKEN=
BRIDGE_WS_URL=ws://127.0.0.1:3001

# ===== Feishu Adapter =====
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_RECEIVE_ID_TYPE=chat_id
FEISHU_WS_LOGGER_LEVEL=debuf

# 可选：自定义 env 文件路径（默认读取当前目录 .env）
# FEISHU_ENV_FILE=./.env
